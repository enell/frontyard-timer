{
	"name": "frontyard-ultra",
	"private": true,
	"version": "0.0.0",
	"packageManager": "bun@1.3.10",
	"engines": {
		"bun": ">=1.3.10"
	},
	"type": "module",
	"scripts": {
		"dev": "bun run build:css && (bun run watch:css & bun run watch:js)",
		"build": "bun run build:css && bun run build:js",
		"build:css": "bunx tailwindcss -i ./src/index.css -o ./src/styles.css",
		"build:js": "bun build --target=browser ./index.html --outdir=dist",
		"watch:css": "bunx tailwindcss -i ./src/index.css -o ./src/styles.css --watch",
		"watch:js": "bun build --target=browser ./index.html --outdir=dist --watch",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"test": "bun test",
		"test:watch": "bun test --watch",
		"test:coverage": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"jotai": "^2.18.0",
		"jotai-location": "^0.6.2",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@happy-dom/global-registrator": "^20.0.8",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"globals": "^17.4.0",
		"typescript": "~5.9.3"
	}
}
